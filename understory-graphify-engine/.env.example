# Understory environment configuration
# Copy this file to .env and fill in your local values.
# Never commit .env to a public repository.

# ========================================
# Privacy and network mode
# Default: local. No cloud model requests and no webhook delivery.
# Options: local | embedding | full
# ========================================

UNDERSTORY_NETWORK_MODE=local
UNDERSTORY_WEBHOOK_ENABLED=0

# ========================================
# Model providers (optional)
# Options: zhipu | openai | custom | none
# Embedding and LLM providers can be configured separately.
# ========================================

UNDERSTORY_EMBEDDING_PROVIDER=zhipu
UNDERSTORY_LLM_PROVIDER=zhipu

# Generic settings for plugin UI values or custom OpenAI-compatible services.
# UNDERSTORY_EMBEDDING_API_KEY=your_embedding_key_here
# UNDERSTORY_EMBEDDING_BASE_URL=https://api.openai.com/v1/
# UNDERSTORY_EMBEDDING_MODEL=text-embedding-3-small
# UNDERSTORY_EMBEDDING_DIMENSIONS=1024
# UNDERSTORY_LLM_API_KEY=your_llm_key_here
# UNDERSTORY_LLM_BASE_URL=https://api.openai.com/v1/
# UNDERSTORY_LLM_MODEL=gpt-4o-mini

# ========================================
# Zhipu AI preset
# ========================================

# API keys: https://www.bigmodel.cn/usercenter/proj-mgmt/apikeys
# ZHIPU_API_KEY=your_api_key_here

# Zhipu OpenAI-compatible Base URL
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# Embedding model name
#   - embedding-3  (recommended, custom dimensions 64-2048)
#   - embedding-2  (stable, fixed 1024 dimensions)
ZHIPU_EMBEDDING_MODEL=embedding-3

# Embedding output dimensions. Only applies to embedding-3.
# Suggested values: 512 for a storage/effect balance, or 1024 for stronger quality.
ZHIPU_EMBEDDING_DIMENSIONS=1024
ZHIPU_LLM_MODEL=glm-4-flash

# ========================================
# OpenAI preset
# ========================================

# OPENAI_API_KEY=your_openai_key_here
OPENAI_BASE_URL=https://api.openai.com/v1/
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o-mini

# ========================================
# Custom OpenAI-compatible service
# ========================================

# CUSTOM_OPENAI_API_KEY=your_custom_key_here
# CUSTOM_OPENAI_BASE_URL=http://127.0.0.1:11434/v1/
# CUSTOM_OPENAI_EMBEDDING_MODEL=nomic-embed-text
# CUSTOM_OPENAI_LLM_MODEL=your-chat-model

# ========================================
# Obsidian vault path (optional)
# ========================================

# Absolute path to your local Obsidian vault.
# If unset, pass --vault from the plugin or CLI, or run from a vault folder.
# OBSIDIAN_VAULT_PATH=/Users/yourname/Documents/WorkVault

# obsidian-remote repository path, used for searching skill docs and related repo content.
# If unset, Understory falls back to ~/Projects/obsidian-remote.
# OBSIDIAN_REMOTE_REPO=/Users/yourname/Projects/obsidian-remote
