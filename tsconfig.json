{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "lib": ["ES2020", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noEmit": true,
    "skipLibCheck": true,
    "target": "ES2020",
    "types": ["node", "obsidian"]
  },
  "include": ["src/**/*.js", "scripts/**/*.js", "tests/**/*.js"]
}
